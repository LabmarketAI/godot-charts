; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but the file format allows this.

config_version=5

[application]

config/name="Godot Charts"
config/description="A 3D plotting library for Godot 4, inspired by matplotlib and Chart.js."
config/version="1.0.0"
config/features=PackedStringArray("4.3")
config/icon="res://icon.svg"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_charts/plugin.cfg")
